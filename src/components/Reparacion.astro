---
    import reparacionCelular from "../assets/img/servicio_tecnico.jpg"
---
<!-- REPARACION DE CELULARES  -->
  <section id="reparacion" class="py-20 px-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-blue-600/5 to-transparent pointer-events-none">
    </div>
    <div
      class="absolute top-1/2 left-1/4 w-96 h-96 bg-blue-500/20 rounded-full blur-[140px] animate-pulse pointer-events-none">
    </div>

    <div class="max-w-7xl mx-auto relative z-10">
      <div
        class="relative grid md:grid-cols-2 gap-12 items-center rounded-[32px] p-10 md:p-14 glass-effect border border-slate-200 dark:border-slate-800 overflow-hidden group">

        <div data-aos="fade-right" data-aos-duration="1000" class="relative flex justify-center items-center z-10">
          <div
            class="absolute -top-4 -left-4 z-20 bg-gradient-to-r from-blue-600 to-cyan-500 text-white px-6 py-2 rounded-full font-bold text-sm shadow-2xl animate-bounce">
            <span class="flex items-center gap-2">
              <span class="material-icons-round text-base">speed</span>
              REPARACIÓN EN 40 MIN
            </span>
          </div>

          <div
            class="absolute inset-0 bg-gradient-to-br from-blue-600/20 to-cyan-500/20 blur-[100px] rounded-full animate-pulse">
          </div>

          <div
            class="relative aspect-square w-full max-w-xl rounded-3xl overflow-hidden bg-gradient-to-br from-white to-slate-50 dark:from-slate-900 dark:to-slate-800 shadow-2xl transition-all duration-700 group/img border border-slate-200/50">
            <img alt="Servicio técnico especializado en celulares" src={reparacionCelular.src}
              class="w-full h-full object-cover group-hover/img:scale-105 transition-transform duration-700" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>
          </div>

          <div
            class="absolute bottom-12 -left-4 bg-white dark:bg-slate-800 rounded-2xl shadow-xl p-4 animate-float hidden md:block border border-blue-600/20">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 bg-blue-500/10 rounded-xl flex items-center justify-center">
                <span class="material-icons-round text-blue-600 text-2xl">phonelink_erase</span>
              </div>
              <div>
                <p class="font-bold text-sm">Pantallas rotas</p>
                <p class="text-xs text-slate-600">Calidad Original</p>
              </div>
            </div>
          </div>

          <div
            class="absolute top-12 -right-4 bg-white dark:bg-slate-800 rounded-2xl shadow-xl p-4 animate-float-delayed hidden md:block border border-blue-600/20">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 bg-blue-500/10 rounded-xl flex items-center justify-center">
                <span class="material-icons-round text-blue-600 text-2xl">battery_charging_full</span>
              </div>
              <div>
                <p class="font-bold text-sm">Cambio de Batería</p>
                <p class="text-xs text-slate-600">Celdas certificadas</p>
              </div>
            </div>
          </div>
        </div>

        <div data-aos="fade-left" data-aos-duration="1000" class="relative space-y-6 z-10">
          <div
            class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-blue-500/10 border border-blue-500/30 text-blue-600 dark:text-blue-400 font-bold tracking-widest uppercase text-xs backdrop-blur-sm">
            <span class="material-icons-round text-xs">build</span>
            Servicio Técnico Especializado
          </div>

          <h3
            class="text-4xl md:text-5xl font-extrabold tracking-tight leading-tight bg-gradient-to-r from-slate-900 via-blue-600 to-slate-900 dark:from-white dark:via-blue-400 dark:to-white bg-clip-text text-transparent">
            ¿Tu celular falló? <br />Lo dejamos como nuevo.
          </h3>

          <p class="text-lg text-slate-600 dark:text-slate-400 max-w-lg leading-relaxed">
            Especialistas en <strong>iPhone, Samsung y Xiaomi</strong>. Reparamos pantallas, puertos de carga y placas
            base con repuestos de grado A y garantía escrita por cada intervención.
          </p>

          <div class="grid grid-cols-2 gap-4">
            <div
              class="flex items-center gap-3 bg-white/50 dark:bg-slate-800/50 p-3 rounded-xl border border-slate-200 dark:border-slate-700">
              <!-- <span class="material-icons-round text-blue-600">microscope</span> -->
              <span class="text-sm font-semibold">Micro-soldadura (EPROM)</span>
            </div>
            <div
              class="flex items-center gap-3 bg-white/50 dark:bg-slate-800/50 p-3 rounded-xl border border-slate-200 dark:border-slate-700">
              <span class="material-icons-round text-blue-600">water_drop</span>
              <span class="text-sm font-semibold">Limpieza química</span>
            </div>
            <div
              class="flex items-center gap-3 bg-white/50 dark:bg-slate-800/50 p-3 rounded-xl border border-slate-200 dark:border-slate-700">
              <span class="material-icons-round text-blue-600">security</span>
              <span class="text-sm font-semibold">Garantía Real</span>
            </div>
            <div
              class="flex items-center gap-3 bg-white/50 dark:bg-slate-800/50 p-3 rounded-xl border border-slate-200 dark:border-slate-700">
              <span class="material-icons-round text-blue-600">update</span>
              <span class="text-sm font-semibold">Hard Reset</span>
            </div>
          </div>

          <div class="bg-gradient-to-r from-blue-600 to-blue-800 rounded-2xl p-6 text-white shadow-lg">
            <div class="flex items-center gap-4 mb-2">
              <span class="text-xs uppercase tracking-widest opacity-80">Diagnóstico Inicial</span>
              <span class="bg-white/20 px-2 py-0.5 rounded text-[10px] font-bold">GRATIS</span>
            </div>
            <div class="flex items-baseline gap-2">
              <span class="text-4xl font-black">S/ 0</span>
              <span class="text-lg opacity-80">Soles</span>
            </div>
            <p class="text-xs mt-2 opacity-90">*No cobramos por revisar tu equipo. Solo pagas si aceptas la
              reparación.
            </p>
          </div>

          <div class="flex flex-wrap gap-4 pt-4">
            <a target="_blank"
              href="https://wa.me/51927854195?text=Hola!%20Necesito%20cotizar%20la%20reparacion%20de%20mi%20celular"
              class="group relative inline-flex items-center gap-2 bg-green-500 hover:bg-green-600 text-white font-bold px-8 py-4 rounded-full transition-all hover:scale-105 shadow-[0_10px_30px_rgba(34,197,94,0.4)]">
              <!-- <span class="material-icons-round">whatsapp</span> -->
              Cotizar por WhatsApp
            </a>
          </div>

          <div class="flex flex-wrap gap-6 pt-4 border-t border-slate-200 dark:border-slate-800">
            <div class="flex items-center gap-2 text-sm text-slate-600">
              <span class="material-icons-round text-blue-500">verified_user</span>
              <span>Repuestos Certificados</span>
            </div>
            <div class="flex items-center gap-2 text-sm text-slate-600">
              <span class="material-icons-round text-blue-500">schedule</span>
              <span>Mismo día</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>