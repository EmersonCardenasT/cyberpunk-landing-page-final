---
import productoDestacadoIphone from "../assets/img/producto_destacado_iphone.webp";
import productoDestacadoSamsung from "../assets/img/producto_destacado_samsung.webp";
---
<!-- PRODUCTO DESTACADO -->
  <section class="py-24 px-6 bg-white dark:bg-slate-950">
    <div class="max-w-[1600px] mx-auto">

      <div class="text-center mb-20">
        <p class="text-xs font-bold tracking-[0.3em] uppercase text-blue-500 mb-3">Selección Premium</p>
        <h2 class="text-4xl md:text-5xl font-bold text-slate-900 dark:text-white tracking-tight">
          Elige tu próximo flagship
        </h2>
      </div>

      <div class="grid lg:grid-cols-2 gap-16 items-start">

        <div class="flex flex-col xl:flex-row gap-10 items-start">
          <div class="w-full xl:w-[65%] flex flex-col gap-6 group">
            <div
              class="relative rounded-3xl bg-slate-50 dark:bg-slate-900/40 p-2 overflow-hidden border border-slate-100 dark:border-slate-800 shadow-sm">
              <img src={productoDestacadoIphone.src} alt="iPhone 17 Pro Max" loading="lazy"
                decoding="async"
                class="w-full h-auto rounded-2xl object-cover transition-transform duration-700 group-hover:scale-105" 
                  data-aos="fade-right" data-aos-duration="1000"/>
            </div>
            <div class="flex items-center gap-4 justify-center xl:justify-start px-2">
              <span class="flex items-center gap-1.5 text-slate-500 text-[10px] font-bold uppercase tracking-wider">
                <svg class="w-3.5 h-3.5 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                  <path
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" />
                </svg>
                Original
              </span>
              <span
                class="flex items-center gap-1.5 text-slate-500 text-[10px] font-bold uppercase tracking-wider border-l border-slate-200 dark:border-slate-800 pl-4">
                <svg class="w-3.5 h-3.5 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
                  <path
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" />
                </svg>
                Garantía 1 Año
              </span>
            </div>
          </div>

          <div class="w-full xl:w-[35%] flex flex-col gap-8">
            <div>
              <h3 class="text-3xl font-bold mb-2 tracking-tight">iPhone 17 Pro Max</h3>
              <p class="text-slate-500 text-sm font-medium mb-6 uppercase tracking-widest">Ecosistema Apple</p>

              <ul class="space-y-3 mb-8">
                <li class="text-sm text-slate-600 dark:text-slate-400"><strong>Chip:</strong> A19 Pro Bionic</li>
                <li class="text-sm text-slate-600 dark:text-slate-400"><strong>Pantalla:</strong> 6.9" ProMotion</li>
                <li class="text-sm text-slate-600 dark:text-slate-400"><strong>Cámara:</strong> 48MP Pro System</li>
              </ul>

              <div
                class="p-4 rounded-2xl bg-blue-50/50 dark:bg-blue-900/10 border border-blue-100 dark:border-blue-900/30">
                <p class="text-xs font-bold text-blue-600 dark:text-blue-400 uppercase mb-2">¿Por qué elegirlo?</p>
                <p class="text-xs leading-relaxed text-slate-600 dark:text-slate-400 italic">
                  "La integración perfecta con iCloud y el valor de reventa más alto del mercado."
                </p>
              </div>
            </div>

            <div class="flex flex-col gap-3 mt-auto">
              <a href="https://wa.me/51927854195?text=Hola!%20Quiero%20comprar%20el%20iPhone%2017%20Pro%20Max"
                target="_blank"
                class="w-full block text-center py-4 bg-blue-500 dark:bg-white dark:text-slate-900 text-white rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-blue-500 hover:text-white transition-all">
                Comprar ahora
              </a>

              <a href="https://wa.me/51927854195?text=Hola!%20Quiero%20consultar%20stock%20del%20iPhone%2017%20Pro%20Max"
                target="_blank"
                class="w-full block text-center py-4 border border-slate-200 dark:border-slate-800 text-slate-600 dark:text-slate-300 rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-slate-50 dark:hover:bg-slate-900 transition-all">
                Consultar Stock
              </a>

            </div>
          </div>
        </div>

        <div class="flex flex-col xl:flex-row gap-10 items-start">
          <div class="w-full xl:w-[65%] flex flex-col gap-6 group">
            <div
              class="relative rounded-3xl bg-slate-50 dark:bg-slate-900/40 p-2 overflow-hidden border border-slate-100 dark:border-slate-800 shadow-sm">
              <img src={productoDestacadoSamsung.src} alt="Samsung S25 Ultra" loading="lazy"
                decoding="async"
                class="w-full h-auto rounded-2xl object-cover transition-transform duration-700 group-hover:scale-105" 
                  data-aos="fade-left" data-aos-duration="1000"/>
            </div>
            <div class="flex items-center gap-4 justify-center xl:justify-start px-2">
              <span class="flex items-center gap-1.5 text-slate-500 text-[10px] font-bold uppercase tracking-wider">
                <svg class="w-3.5 h-3.5 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                  <path
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" />
                </svg>
                Original
              </span>
              <span
                class="flex items-center gap-1.5 text-slate-500 text-[10px] font-bold uppercase tracking-wider border-l border-slate-200 dark:border-slate-800 pl-4">
                <svg class="w-3.5 h-3.5 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
                  <path
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" />
                </svg>
                Garantía 1 Año
              </span>
            </div>
          </div>

          <div class="w-full xl:w-[35%] flex flex-col gap-8">
            <div>
              <h3 class="text-3xl font-bold mb-2 tracking-tight">Samsung S25 Ultra</h3>
              <p class="text-slate-500 text-sm font-medium mb-6 uppercase tracking-widest">Galaxy Innovation</p>

              <ul class="space-y-3 mb-8">
                <li class="text-sm text-slate-600 dark:text-slate-400"><strong>Procesador:</strong> Snapdragon 8 Gen 4
                </li>
                <li class="text-sm text-slate-600 dark:text-slate-400"><strong>Pantalla:</strong> AMOLED 2X 6.9"</li>
                <li class="text-sm text-slate-600 dark:text-slate-400"><strong>Cámara:</strong> 200MP + AI Zoom</li>
              </ul>

              <div
                class="p-4 rounded-2xl bg-purple-50/50 dark:bg-purple-900/10 border border-purple-100 dark:border-purple-900/30">
                <p class="text-xs font-bold text-purple-600 dark:text-purple-400 uppercase mb-2">¿Por qué elegirlo?</p>
                <p class="text-xs leading-relaxed text-slate-600 dark:text-slate-400 italic">
                  "La libertad del S Pen y el sistema de zoom fotográfico más potente del mundo."
                </p>
              </div>
            </div>

            <div class="flex flex-col gap-3 mt-auto">
              <a href="https://wa.me/51927854195?text=Hola!%20Quiero%20comprar%20el%20Samsung S25%20Ultra"
                target="_blank"
                class="w-full block text-center py-4 bg-blue-500 dark:bg-white dark:text-slate-900 text-white rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-blue-500 hover:text-white transition-all">
                Comprar ahora
              </a>

              <a href="https://wa.me/51927854195?text=Hola!%20Quiero%20consultar%20stock%20del%20Samsung S25%20Ultra"
                target="_blank"
                class="w-full block text-center py-4 border border-slate-200 dark:border-slate-800 text-slate-600 dark:text-slate-300 rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-slate-50 dark:hover:bg-slate-900 transition-all">
                Consultar Stock
              </a>

            </div>
          </div>
        </div>

      </div>
    </div>
  </section>