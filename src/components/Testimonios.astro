<!-- ════════════════════════════════════════════════════
  JAVASCRIPT (solo lógica runtime: contador + observer)
  Los datos y el HTML ya fueron generados en build time.
════════════════════════════════════════════════════ -->
<script>
  "use strict";

  /* ── Contador animado ── */
  function easeOutQuart(t: number): number {
    return 1 - Math.pow(1 - t, 4);
  }

  function animateCount(el: HTMLElement): void {
    if (el.dataset.static) return;

    const isFloat = el.dataset.float === "true";
    const target = parseFloat(el.dataset.target ?? "0");
    const suffix = el.dataset.suffix ?? "";
    const duration = 2000;
    const start = performance.now();

    el.classList.add("counting");

    function step(now: number): void {
      const progress = Math.min((now - start) / duration, 1);
      const eased = easeOutQuart(progress);
      const current = isFloat
        ? (eased * target).toFixed(1)
        : Math.floor(eased * target).toLocaleString();

      el.textContent = current + suffix;

      if (progress < 1) {
        requestAnimationFrame(step);
      } else {
        el.textContent =
          (isFloat ? target.toFixed(1) : target.toLocaleString()) + suffix;
        el.classList.remove("counting");
      }
    }

    requestAnimationFrame(step);
  }

  function activateStats(): void {
    document.querySelectorAll<HTMLElement>(".stat-item").forEach((item, i) => {
      item.style.opacity = "";
      item.classList.add("fade-up");

      setTimeout(() => {
        const el = item.querySelector<HTMLElement>(".stat-number");
        if (el) animateCount(el);
      }, i * 150);
    });
  }

  /* ── IntersectionObserver: anima solo cuando es visible ── */
  const statsGrid = document.getElementById("stats-grid");
  let animated = false;

  if (statsGrid) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !animated) {
            animated = true;
            activateStats();
            observer.disconnect();
          }
        });
      },
      { threshold: 0.3 },
    );
    observer.observe(statsGrid);
  }
</script>
