<style>
  /* ── Carrusel animaciones ── */
  @keyframes scroll-right {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
  @keyframes scroll-left {
    0% {
      transform: translateX(-50%);
    }
    100% {
      transform: translateX(0);
    }
  }

  .animate-scroll-right {
    animation: scroll-right 35s linear infinite;
  }
  .animate-scroll-left {
    animation: scroll-left 35s linear infinite;
  }

  /* Pausar al hover sobre la fila contenedora */
  .carousel-row:hover .animate-scroll-right,
  .carousel-row:hover .animate-scroll-left {
    animation-play-state: paused;
  }

  /* ── Tarjeta mini ── */
  .testimonial-mini {
    position: relative;
    backdrop-filter: blur(10px);
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }
  .testimonial-mini:hover {
    transform: translateY(-4px) scale(1.03);
    box-shadow: 0 16px 40px rgba(59, 130, 246, 0.18);
  }
  .testimonial-mini::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 1rem;
    padding: 1.5px;
    background: linear-gradient(
      135deg,
      transparent,
      rgba(59, 130, 246, 0.5),
      transparent
    );
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }
  .testimonial-mini:hover::before {
    opacity: 1;
  }

  /* ── Stats — animación de conteo ── */
  .stat-number {
    font-variant-numeric: tabular-nums;
    transition: color 0.3s;
  }

  @keyframes stat-pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.75;
    }
  }
  .counting {
    animation: stat-pulse 0.6s ease infinite;
  }

  /* ── Fade-in de sección ── */
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .fade-up {
    animation: fadeUp 0.7s ease forwards;
  }

  .stat-item:nth-child(1) {
    animation-delay: 0s;
  }
  .stat-item:nth-child(2) {
    animation-delay: 0.15s;
  }
  .stat-item:nth-child(3) {
    animation-delay: 0.3s;
  }
  .stat-item:nth-child(4) {
    animation-delay: 0.45s;
  }
</style>

