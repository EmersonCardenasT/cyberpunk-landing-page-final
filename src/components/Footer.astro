---
import FondoCyberpunk from "../assets/img/fondo_cyberpunk.webp";
import logoCyberpunk from "../assets/img/logo_cyberpunk.webp";
---

<footer
  class="relative pt-20 pb-6 px-6 text-white overflow-hidden bg-slate-950"
>
  <!-- Background con efecto parallax -->
  <div
    class="absolute inset-0 bg-cover bg-center bg-fixed"
    style={`background-image: url(${FondoCyberpunk.src});`}
  >
  </div>

  <!-- Overlay con gradiente -->
  <div
    class="absolute inset-0 bg-gradient-to-b from-black/80 via-black/85 to-black/95"
  >
  </div>

  <!-- Efectos decorativos animados -->
  <div
    class="absolute top-20 left-10 w-96 h-96 bg-blue-600/10 rounded-full blur-[120px] animate-pulse pointer-events-none"
  >
  </div>
  <div
    class="absolute bottom-20 right-10 w-80 h-80 bg-blue-500/10 rounded-full blur-[100px] animate-pulse pointer-events-none"
    style="animation-delay: 1.5s;"
  >
  </div>

  <!-- Contenido principal -->
  <div class="relative z-10">
    <div class="max-w-7xl mx-auto">
      <!-- Sección principal con grid MEJORADO -->
      <div
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-12 gap-8 lg:gap-12 mb-16"
      >
        <!-- Brand & Description - FULL WIDTH en mobile -->
        <div
          data-aos="fade-up"
          data-aos-duration="1000"
          class="col-span-1 sm:col-span-2 lg:col-span-4"
        >
          <!-- Logo -->
          <div class="flex items-center gap-3 mb-6 group cursor-pointer">
            <img
              src={logoCyberpunk.src}
              alt="Cyberpunk Store"
              loading="lazy"
              class="h-10 sm:h-12 w-auto group-hover:scale-110 transition-transform"
            />
            <div>
              <span class="text-xl sm:text-2xl font-bold tracking-tight block"
                >Cyberpunk</span
              >
              <span class="text-xs text-blue-500 font-semibold">Tech Store</span
              >
            </div>
          </div>

          <p class="text-slate-300 text-sm leading-relaxed mb-6">
            Tu tienda de confianza para celulares nuevos, seminuevos y
            reparaciones profesionales. Más de 8 años brindando calidad y
            servicio excepcional.
          </p>

          <!-- Certificaciones/Badges -->
          <div class="flex flex-wrap gap-3 mb-6">
            <div
              class="flex items-center gap-2 bg-white/10 backdrop-blur-sm px-3 py-2 rounded-lg border border-white/20"
            >
              <span class="material-icons-round text-green-400 text-sm"
                >verified</span
              >
              <span class="text-xs font-semibold">Garantía Oficial</span>
            </div>
            <div
              class="flex items-center gap-2 bg-white/10 backdrop-blur-sm px-3 py-2 rounded-lg border border-white/20"
            >
              <span class="material-icons-round text-blue-400 text-sm"
                >security</span
              >
              <span class="text-xs font-semibold">Pago Seguro</span>
            </div>
          </div>

          <!-- Redes sociales mejoradas -->
          <div>
            <p class="text-sm font-semibold mb-3 text-slate-300">Síguenos</p>
            <div class="flex gap-3">
              <a
                href="https://www.facebook.com/"
                target="_blank"
                rel="noopener noreferrer"
                class="group w-11 h-11 rounded-xl bg-white/10 backdrop-blur-sm border border-white/20 flex items-center justify-center hover:bg-blue-600 hover:border-blue-600 transition-all hover:scale-110"
                aria-label="Facebook"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path
                    d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
                  ></path>
                </svg>
              </a>

              <a
                href="https://www.instagram.com/cyberpunk.pe/"
                target="_blank"
                rel="noopener noreferrer"
                class="group w-11 h-11 rounded-xl bg-white/10 backdrop-blur-sm border border-white/20 flex items-center justify-center hover:bg-gradient-to-br hover:from-purple-600 hover:to-pink-600 hover:border-pink-600 transition-all hover:scale-110"
                aria-label="Instagram"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path
                    d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
                  ></path>
                </svg>
              </a>

              <a
                href="https://wa.me/51927854195"
                target="_blank"
                rel="noopener noreferrer"
                class="group w-11 h-11 rounded-xl bg-white/10 backdrop-blur-sm border border-white/20 flex items-center justify-center hover:bg-green-600 hover:border-green-600 transition-all hover:scale-110"
                aria-label="WhatsApp"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path
                    d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
                  ></path>
                </svg>
              </a>

              <a
                href="https://www.tiktok.com/@cyberpunk.pe"
                target="_blank"
                rel="noopener noreferrer"
                class="group w-11 h-11 rounded-xl bg-white/10 backdrop-blur-sm border border-white/20 flex items-center justify-center hover:bg-black hover:border-white transition-all hover:scale-110"
                aria-label="TikTok"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path
                    d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"
                  ></path>
                </svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Columna 1: Tienda -->
        <div
          data-aos="fade-up"
          data-aos-duration="1000"
          data-aos-delay="100"
          class="col-span-1 sm:col-span-1 lg:col-span-2"
        >
          <h6
            class="font-bold text-base sm:text-lg mb-4 sm:mb-6 flex items-center gap-2"
          >
            <span class="material-icons-round text-blue-500 text-xl"
              >storefront</span
            >
            Tienda
          </h6>
          <ul class="space-y-2 sm:space-y-3 text-slate-300 text-sm">
            <li>
              <a
                class="hover:text-blue-500 transition-colors flex items-center gap-2 group"
                href="#products"
              >
                <span
                  class="material-icons-round text-xs group-hover:translate-x-1 transition-transform"
                  >arrow_forward</span
                >
                Celulares Nuevos
              </a>
            </li>
            <li>
              <a
                class="hover:text-blue-500 transition-colors flex items-center gap-2 group"
                href="#products"
              >
                <span
                  class="material-icons-round text-xs group-hover:translate-x-1 transition-transform"
                  >arrow_forward</span
                >
                Seminuevos
              </a>
            </li>
            <li>
              <a
                class="hover:text-blue-500 transition-colors flex items-center gap-2 group"
                href="#products"
              >
                <span
                  class="material-icons-round text-xs group-hover:translate-x-1 transition-transform"
                  >arrow_forward</span
                >
                Accesorios
              </a>
            </li>
            <li>
              <a
                class="hover:text-blue-500 transition-colors flex items-center gap-2 group"
                href="#reparacion"
              >
                <span
                  class="material-icons-round text-xs group-hover:translate-x-1 transition-transform"
                  >arrow_forward</span
                >
                Reparaciones
              </a>
            </li>
            <li>
              <a
                class="hover:text-blue-500 transition-colors flex items-center gap-2 group"
                href="#gallery"
              >
                <span
                  class="material-icons-round text-xs group-hover:translate-x-1 transition-transform"
                  >arrow_forward</span
                >
                Ofertas Especiales
              </a>
            </li>
          </ul>
        </div>

        <!-- Columna 2: Servicios -->
        <div
          data-aos="fade-up"
          data-aos-duration="1000"
          data-aos-delay="200"
          class="col-span-1 sm:col-span-1 lg:col-span-2"
        >
          <h6
            class="font-bold text-base sm:text-lg mb-4 sm:mb-6 flex items-center gap-2"
          >
            <span class="material-icons-round text-blue-500 text-xl">build</span
            >
            Servicios
          </h6>
          <ul class="space-y-2 sm:space-y-3 text-slate-300 text-sm">
            <li>
              <a
                class="hover:text-blue-500 transition-colors flex items-center gap-2 group"
                href="#reparacion"
              >
                <span
                  class="material-icons-round text-xs group-hover:translate-x-1 transition-transform"
                  >arrow_forward</span
                >
                Cambio de Pantalla
              </a>
            </li>
            <li>
              <a
                class="hover:text-blue-500 transition-colors flex items-center gap-2 group"
                href="#reparacion"
              >
                <span
                  class="material-icons-round text-xs group-hover:translate-x-1 transition-transform"
                  >arrow_forward</span
                >
                Cambio de Batería
              </a>
            </li>
            <li>
              <a
                class="hover:text-blue-500 transition-colors flex items-center gap-2 group"
                href="#reparacion"
              >
                <span
                  class="material-icons-round text-xs group-hover:translate-x-1 transition-transform"
                  >arrow_forward</span
                >
                Liberación
              </a>
            </li>
            <li>
              <a
                class="hover:text-blue-500 transition-colors flex items-center gap-2 group"
                href="#reparacion"
              >
                <span
                  class="material-icons-round text-xs group-hover:translate-x-1 transition-transform"
                  >arrow_forward</span
                >
                Diagnóstico Gratuito
              </a>
            </li>
          </ul>
        </div>

        <!-- Columna 3: Empresa -->
        <div
          data-aos="fade-up"
          data-aos-duration="1000"
          data-aos-delay="300"
          class="col-span-1 sm:col-span-1 lg:col-span-2"
        >
          <h6
            class="font-bold text-base sm:text-lg mb-4 sm:mb-6 flex items-center gap-2"
          >
            <span class="material-icons-round text-blue-500 text-xl"
              >business</span
            >
            Empresa
          </h6>
          <ul class="space-y-2 sm:space-y-3 text-slate-300 text-sm">
            <li>
              <a
                class="hover:text-blue-500 transition-colors flex items-center gap-2 group"
                href="#vision"
              >
                <span
                  class="material-icons-round text-xs group-hover:translate-x-1 transition-transform"
                  >arrow_forward</span
                >
                Sobre Nosotros
              </a>
            </li>
            <li>
              <a
                class="hover:text-blue-500 transition-colors flex items-center gap-2 group"
                href="#testimonios"
              >
                <span
                  class="material-icons-round text-xs group-hover:translate-x-1 transition-transform"
                  >arrow_forward</span
                >
                Testimonios
              </a>
            </li>
            <li>
              <a
                class="hover:text-blue-500 transition-colors flex items-center gap-2 group"
                href="#gallery"
              >
                <span
                  class="material-icons-round text-xs group-hover:translate-x-1 transition-transform"
                  >arrow_forward</span
                >
                Galería
              </a>
            </li>
            <li>
              <a
                class="hover:text-blue-500 transition-colors flex items-center gap-2 group"
                href="#"
              >
                <span
                  class="material-icons-round text-xs group-hover:translate-x-1 transition-transform"
                  >arrow_forward</span
                >
                Trabaja con Nosotros
              </a>
            </li>
          </ul>
        </div>

        <!-- Columna 4: Contacto - MEJORADO para mobile -->
        <div
          data-aos="fade-up"
          data-aos-duration="1000"
          data-aos-delay="400"
          class="col-span-1 sm:col-span-2 lg:col-span-2"
        >
          <h6
            class="font-bold text-base sm:text-lg mb-4 sm:mb-6 flex items-center gap-2"
          >
            <span class="material-icons-round text-blue-500 text-xl"
              >contact_support</span
            >
            Contacto
          </h6>
          <ul class="space-y-3 sm:space-y-4 text-slate-300 text-sm">
            <li class="flex items-start gap-3">
              <a
                class="hover:text-blue-500 transition-colors flex items-center gap-2 group"
                href="https://maps.app.goo.gl/SZdaX8rwYwU4FG2d7"
                target="_blank"
                rel="noopener noreferrer"
              >
                <span
                  class="material-icons-round text-blue-500 text-xl flex-shrink-0 mt-0.5"
                  >location_on</span
                >
                <span class="break-words leading-relaxed">
                  Av. Micaela Bastidas con Jr. 9 Diciembre N° 195<br
                    class="hidden sm:inline"
                  />
                  <span class="block sm:inline">(Misma Esquina)</span>
                </span>
              </a>
            </li>
            <li class="flex items-start gap-3">
              <span
                class="material-icons-round text-blue-500 text-xl flex-shrink-0 mt-0.5"
                >phone</span
              >
              <div>
                <a
                  href="tel:+51927854195"
                  class="hover:text-blue-500 transition-colors block"
                  >+51 927 854 195</a
                >
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span
                class="material-icons-round text-blue-500 text-xl flex-shrink-0 mt-0.5"
                >email</span
              >
              <a
                href="mailto:contacto@cyberpunk.com"
                class="hover:text-blue-500 transition-colors break-all"
                >cyberpunkcompany@<wbr />gmail.com</a
              >
            </li>
            <li class="flex items-start gap-3">
              <span
                class="material-icons-round text-blue-500 text-xl flex-shrink-0 mt-0.5"
                >schedule</span
              >
              <div>
                <p>Lun - Dom:<br class="sm:hidden" /> 8:00 AM - 9:00 PM</p>
              </div>
            </li>
          </ul>
        </div>
      </div>

      <!-- Métodos de pago -->
      <div
        data-aos="fade-up"
        data-aos-duration="1000"
        class="mb-12 pb-12 border-b border-white/10"
      >
        <div class="text-center mb-6">
          <p class="text-sm font-semibold text-slate-300 mb-4">
            Métodos de Pago Aceptados
          </p>
          <div
            class="flex flex-wrap justify-center items-center gap-4 sm:gap-6"
          >
            <div
              class="w-14 h-9 sm:w-16 sm:h-10 bg-white rounded-lg flex items-center justify-center"
            >
              <span class="text-blue-600 font-bold text-xs">VISA</span>
            </div>
            <div
              class="w-14 h-9 sm:w-16 sm:h-10 bg-white rounded-lg flex items-center justify-center"
            >
              <span class="text-red-600 font-bold text-xs">Master</span>
            </div>
            <div
              class="w-14 h-9 sm:w-16 sm:h-10 bg-white rounded-lg flex items-center justify-center"
            >
              <span class="text-blue-800 font-bold text-xs">Yape</span>
            </div>
            <div
              class="w-14 h-9 sm:w-16 sm:h-10 bg-white rounded-lg flex items-center justify-center"
            >
              <span class="text-purple-800 font-bold text-xs">Plin</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Bottom copyright - MEJORADO -->
      <div
        class="flex flex-col md:flex-row items-center justify-between gap-4 sm:gap-6 text-xs text-slate-400"
      >
        <div
          class="flex flex-col md:flex-row items-center gap-2 sm:gap-4 text-center md:text-left"
        >
          <p>© 2026 Cyberpunk Tech Store. Todos los derechos reservados.</p>
          <span class="hidden md:block">|</span>
          <p class="flex items-center gap-1 flex-wrap justify-center">
            Desarrollado con <i class="fa fa-heart" aria-hidden="true"></i> por <a
              href="#"
              class="text-blue-500 hover:text-blue-400 transition-colors font-semibold ml-1"
              >PXCode Software Solutions</a
            >
          </p>
        </div>

        <div class="flex flex-wrap gap-4 sm:gap-6 justify-center">
          <a
            class="hover:text-blue-500 transition-colors flex items-center gap-1"
            href="#"
          >
            <span class="material-icons-round text-xs">privacy_tip</span>
            Privacidad
          </a>
          <a
            class="hover:text-blue-500 transition-colors flex items-center gap-1"
            href="#"
          >
            <span class="material-icons-round text-xs">description</span>
            Términos
          </a>
          <a
            class="hover:text-blue-500 transition-colors flex items-center gap-1"
            href="#"
          >
            <span class="material-icons-round text-xs">cookie</span>
            Cookies
          </a>
          <a
            class="hover:text-blue-500 transition-colors flex items-center gap-1"
            href="#"
          >
            <span class="material-icons-round text-xs">local_shipping</span>
            Envíos
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  /* Animación suave para scroll */
  html {
    scroll-behavior: smooth;
  }

  /* Efecto parallax en el fondo */
  @media (min-width: 768px) {
    footer .bg-fixed {
      background-attachment: fixed;
    }
  }

  /* Breakpoint de palabra para emails largos */
  a[href^="mailto:"] {
    word-break: break-all;
  }

  /* Animación de entrada para el scroll to top */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
