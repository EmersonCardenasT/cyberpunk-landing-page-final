<!-- ════════════════════════════════════════════════════════
  ESTILOS
════════════════════════════════════════════════════════ -->
<style>
  /* ── Scrollbar oculto ── */
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

  /* ── Fade-in de tarjetas ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .product-card { animation: fadeUp .5s ease forwards; }

  /* ── Última tarjeta con fade visual ── */
  .card-fade::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: .75rem;
    background: linear-gradient(to right, transparent 30%, rgba(255,255,255,.85) 100%);
    pointer-events: none;
    transition: opacity .3s;
  }
  .dark .card-fade::after {
    background: linear-gradient(to right, transparent 30%, rgba(15,23,42,.85) 100%);
  }
  .card-fade:hover::after { opacity: 0; }

  /* ══ MODAL ══════════════════════════════════════════════ */
  #modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0,0,0,.65);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity .25s ease;
  }
  #modal-overlay.open { opacity: 1; pointer-events: all; }

  #modal-box {
    background: #fff;
    border-radius: 1.5rem;
    width: 100%;
    max-width: 640px;
    max-height: 90vh;
    overflow-y: auto;
    position: relative;
    transform: scale(.93) translateY(16px);
    transition: transform .28s cubic-bezier(.34,1.56,.64,1);
    box-shadow: 0 30px 70px rgba(0,0,0,.25);
  }
  .dark #modal-box { background: #0f172a; }
  #modal-overlay.open #modal-box { transform: scale(1) translateY(0); }

  #modal-close {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 10;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: rgba(0,0,0,.08);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    color: #64748b;
    transition: background .15s, color .15s;
  }
  .dark #modal-close { background: rgba(255,255,255,.1); color: #94a3b8; }
  #modal-close:hover { background: rgba(0,0,0,.18); color: #0f172a; }
  .dark #modal-close:hover { background: rgba(255,255,255,.2); color: #fff; }

  /* Specs table */
  .spec-row {
    display: flex;
    gap: 10px;
    padding: 7px 0;
    border-bottom: 1px solid rgba(59,130,246,.08);
    font-size: .82rem;
  }
  .spec-key { font-weight: 700; color: #3b82f6; min-width: 130px; flex-shrink: 0; }
  .dark .spec-key { color: #60a5fa; }

  /* WA button */
  .btn-wa {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    margin-top: 20px;
    padding: 14px 20px;
    background: linear-gradient(135deg, #25d366, #128c7e);
    color: #fff;
    border: none;
    border-radius: 12px;
    font-size: .95rem;
    font-weight: 700;
    cursor: pointer;
    text-decoration: none;
    transition: opacity .2s, transform .2s;
  }
  .btn-wa:hover { opacity: .9; transform: translateY(-2px); }
</style>

