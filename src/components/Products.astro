  Nota: se usa is:inline para acceder a los datos del DOM.
  Toda la lógica de datos ya fue procesada en el frontmatter.
════════════════════════════════════════════════════════ -->
<script is:inline define:vars={{ WHATSAPP }}>
  'use strict';

  /* ── Controles de slider ── */
  document.querySelectorAll('.slider-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const el = document.getElementById(btn.dataset.slider);
      if (el) el.scrollBy({ left: btn.dataset.dir === 'left' ? -320 : 320, behavior: 'smooth' });
    });
  });

  /* ── Drag en sliders ── */
  document.querySelectorAll('[id$="-slider"]').forEach((el) => {
    let down = false, startX, scrollLeft;
    el.addEventListener('mousedown', (e) => {
      down = true;
      startX = e.pageX - el.offsetLeft;
      scrollLeft = el.scrollLeft;
      el.style.scrollBehavior = 'auto';
    });
    el.addEventListener('mouseleave', () => { down = false; });
    el.addEventListener('mouseup', () => { down = false; el.style.scrollBehavior = 'smooth'; });
    el.addEventListener('mousemove', (e) => {
      if (!down) return;
      e.preventDefault();
      el.scrollLeft = scrollLeft - (e.pageX - el.offsetLeft - startX) * 2;
    });
  });

  /* ── Modal ── */
  const overlay   = document.getElementById('modal-overlay');
  const modalBody = document.getElementById('modal-body');

  function openModal(product) {
    const waMsg = encodeURIComponent(
      `Hola! Me interesa comprar: *${product.name}*\nPrecio: ${product.price}\n¿Tienen disponibilidad?`
    );
    const waUrl = `https://wa.me/${WHATSAPP}?text=${waMsg}`;

    const specsHTML = product.specs
      .map(([k, v]) => `
        <div class="spec-row">
          <span class="spec-key">${k}</span>
          <span class="text-slate-700 dark:text-slate-300">${v}</span>
        </div>`)
      .join('');

    modalBody.innerHTML = `
      <div class="relative h-56 sm:h-72 bg-slate-100 dark:bg-slate-800 rounded-t-3xl overflow-hidden">
        <img
          src="${product.image}"
          alt="${product.name}"
          class="w-full h-full object-contain p-6"
        />
        <span class="absolute top-4 left-4 ${product.discountColor}
                     text-white text-xs font-black px-3 py-1.5 rounded-full shadow">
          ${product.discount}
        </span>
      </div>
      <div class="p-6 sm:p-8 dark:bg-slate-800 dark:text-slate-300">
        <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 mb-6">
          <h3 class="text-xl font-black text-slate-900 dark:text-white leading-tight">
            ${product.name}
          </h3>
          <div class="text-right flex-shrink-0">
            <p class="text-xs text-slate-400 line-through">${product.originalPrice}</p>
            <p class="text-2xl font-black text-blue-600">${product.price}</p>
            <p class="text-xs text-slate-500 dark:text-slate-400">Ahorra ${product.savings}</p>
          </div>
        </div>
        <p class="text-[10px] font-black uppercase tracking-widest text-blue-600 mb-3">
          Especificaciones Técnicas
        </p>
        <div class="mb-6">${specsHTML}</div>
        <a href="${waUrl}" target="_blank" rel="noopener noreferrer" class="bg-blue-600 text-white px-6 py-2.5 rounded-full shadow-md hover:bg-blue-700 transition-colors">
          
          Comprar por WhatsApp
        </a>
      </div>`;

    overlay.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    overlay.classList.remove('open');
    document.body.style.overflow = '';
  }

  document.getElementById('modal-close').addEventListener('click', closeModal);
  overlay.addEventListener('click', (e) => { if (e.target === overlay) closeModal(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

  /* ── Delegación de eventos en tarjetas ── */
  document.getElementById('sliders-container').addEventListener('click', (e) => {
    // ¿Clic en "Comprar"?
    const buyBtn = e.target.closest('.btn-comprar');
    if (buyBtn) {
      e.stopPropagation();
      const msg = encodeURIComponent(
        `Hola! Quiero comprar: *${buyBtn.dataset.name}*\nPrecio: ${buyBtn.dataset.price}\n¿Tienen stock disponible?`
      );
      window.open(`https://wa.me/${WHATSAPP}?text=${msg}`, '_blank');
      return;
    }
    // ¿Clic en tarjeta?
    const card = e.target.closest('[data-product]');
    if (card) openModal(JSON.parse(card.dataset.product));
  });

  // Accesibilidad: Enter / Space → modal
  document.getElementById('sliders-container').addEventListener('keydown', (e) => {
    if (e.key !== 'Enter' && e.key !== ' ') return;
    const card = e.target.closest('[data-product]');
    if (card) { e.preventDefault(); openModal(JSON.parse(card.dataset.product)); }
  });
</script>