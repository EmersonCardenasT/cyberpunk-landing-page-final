<section
  id="products"
  class="py-20 px-6 bg-gradient-to-b from-white via-slate-50 to-white
         dark:from-slate-950 dark:via-slate-900 dark:to-slate-950 overflow-hidden"
>
  <!-- Título general -->
  <div class="max-w-[1700px] mx-auto text-center mb-16">
    <p class="text-blue-600 font-bold tracking-widest uppercase text-sm mb-3 flex items-center justify-center gap-2">
      <span class="material-icons-round text-base">smartphone</span>
      Catálogo Premium
    </p>
    <h2
      class="text-4xl md:text-6xl font-extrabold mb-4
             bg-gradient-to-r from-slate-900 via-blue-600 to-slate-900
             dark:from-white dark:via-blue-600 dark:to-white
             bg-clip-text text-transparent"
    >
      NUESTROS PRODUCTOS
    </h2>
    <p class="text-slate-600 dark:text-slate-400 max-w-3xl mx-auto text-lg">
      Descubre las últimas novedades en tecnología móvil con los mejores precios del mercado
    </p>
    <div class="flex items-center justify-center gap-2 mt-6">
      <div class="h-px w-16 bg-gradient-to-r from-transparent to-blue-600"></div>
      <div class="w-2 h-2 rounded-full bg-blue-500"></div>
      <div class="h-px w-16 bg-gradient-to-l from-transparent to-blue-600"></div>
    </div>
  </div>

  <!-- Sliders por marca -->
  <div id="sliders-container" class="max-w-[1700px] mx-auto">
    {BRANDS.map((brand) => (
      <div class="mb-20">
        <div class="flex flex-col lg:flex-row gap-8">

          <!-- Encabezado lateral de la marca -->
          <div class="lg:w-1/4 flex flex-col justify-center">
            <p class="text-blue-600 font-bold tracking-[.3em] uppercase text-xs mb-4">
              {brand.label}
            </p>
            <h3 class="text-5xl md:text-6xl font-black tracking-tighter
                       text-slate-900 dark:text-white uppercase leading-[.9]">
              {brand.title[0]}<br />{brand.title[1]}<br />
              <span class="text-blue-600">{brand.title[2]}</span>
            </h3>
            <p class="mt-6 text-slate-500 dark:text-slate-400 text-sm max-w-xs italic">
              {brand.description}
            </p>
            <!-- Controles del slider -->
            <div class="flex gap-2 mt-6">
              <button
                data-slider={`${brand.id}-slider`}
                data-dir="left"
                class="slider-btn p-3 rounded-lg border border-slate-200 dark:border-slate-800
                       hover:bg-blue-500 hover:text-white hover:border-blue-500
                       transition-all duration-300 hover:scale-110"
                aria-label="Anterior"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
              </button>
              <button
                data-slider={`${brand.id}-slider`}
                data-dir="right"
                class="slider-btn p-3 rounded-lg border border-slate-200 dark:border-slate-800
                       hover:bg-blue-500 hover:text-white hover:border-blue-500
                       transition-all duration-300 hover:scale-110"
                aria-label="Siguiente"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </button>
            </div>
          </div>

          <!-- Slider de tarjetas -->
          <div class="lg:w-3/4 overflow-visible">
            <div
              id={`${brand.id}-slider`}
              class="flex gap-5 overflow-x-auto pb-12 pt-6 px-2
                     snap-x snap-mandatory no-scrollbar
                     cursor-grab active:cursor-grabbing scroll-smooth"
            >
              {brand.products.map((product, index) => (
                <article
                  class:list={[
                    "product-card relative min-w-[270px] md:min-w-[305px] snap-start",
                    "bg-white dark:bg-slate-900 rounded-xl p-4 border border-slate-100",
                    "dark:border-slate-800 cursor-pointer select-none",
                    "transition-all duration-400 hover:scale-105 hover:-translate-y-3",
                    "hover:shadow-[0_20px_40px_rgba(59,130,246,.28)]",
                    product.fade ? "card-fade opacity-50 hover:opacity-100" : "",
                  ]}
                  style={`animation-delay:${(index + 1) * 80}ms`}
                  tabindex="0"
                  role="button"
                  aria-label={`Ver detalles de ${product.name}`}
                  data-product={JSON.stringify({
                    name: product.name,
                    // Astro resuelve image.src como la URL pública optimizada
                    image: product.image.src,
                    originalPrice: product.originalPrice,
                    price: product.price,
                    savings: product.savings,
                    discount: product.discount,
                    discountColor: product.discountColor,
                    specs: product.specs,
                  })}
                >
                  <!-- Badge de descuento -->
                  <span
                    class:list={[
                      "absolute top-5 right-5 z-10 text-white text-xs font-black px-3 py-1.5 rounded-full shadow-lg",
                      product.discountColor,
                    ]}
                  >
                    {product.discount}
                  </span>

                  <!-- Imagen — componente nativo de Astro para optimización automática -->
                  <div class="w-full aspect-[4/5] mb-4 rounded-lg overflow-hidden
                              bg-slate-50 dark:bg-slate-800/30 flex items-center justify-center">
                    <img
                      src={product.image.src}
                      alt={product.name}
                      width={product.image.width}
                      height={product.image.height}
                      loading="lazy"
                      decoding="async"
                      class="w-full h-full object-contain p-2
                             transition-transform duration-600 group-hover:scale-110"
                    />
                  </div>

                  <!-- Info -->
                  <div class="space-y-2">
                    <h4 class="font-bold text-sm tracking-tight text-slate-900 dark:text-white
                               leading-snug group-hover:text-blue-600 transition-colors line-clamp-2">
                      {product.name}
                    </h4>
                    <div class="flex flex-col">
                      <span class="text-xs text-slate-400 line-through">{product.originalPrice}</span>
                      <span class="text-2xl font-black text-blue-600 leading-none">{product.price}</span>
                      <span class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">
                        Ahorra {product.savings}
                      </span>
                    </div>

                    <!-- Botón COMPRAR — abre WhatsApp directamente, sin modal -->
                    <div class="flex justify-end pt-1">
                      <button
                        class="btn-comprar flex items-center gap-2 px-5 py-2.5 bg-blue-500 text-white
                               rounded-lg text-sm font-bold hover:bg-blue-600
                               transition-all hover:shadow-lg hover:scale-105 active:scale-95"
                        data-name={product.name}
                        data-price={product.price}
                      >
                        Comprar
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293
                               2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0
                               000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
                        </svg>
                      </button>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </div>

        <!-- Separador -->
        <div class="h-px bg-gradient-to-r from-transparent via-slate-300 dark:via-slate-700 to-transparent my-4 mb-16"></div>
      </div>
    ))}
  </div>
</section>

